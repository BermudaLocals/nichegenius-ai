# ============================================
# NicheGenius AI - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ---- Application ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="NicheGenius AI"
NODE_ENV=development

# ---- Database (PostgreSQL / Neon) ----
DATABASE_URL="postgresql://user:password@host:5432/nichegenius?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/nichegenius?sslmode=require"

# ---- Clerk Authentication ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/assessment

# ---- Stripe Payments ----
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_STARTER=price_xxxxx
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxx

# ---- OpenAI (GPT-4o) ----
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Google AI (Gemma 2) ----
GOOGLE_GENERATIVE_AI_API_KEY=xxxxx
GOOGLE_AI_MODEL=gemma-2-27b-it

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- Pinecone Vector Database ----
PINECONE_API_KEY=xxxxx
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=nichegenius-knowledge
PINECONE_NAMESPACE=niche-data

# ---- HeyGen AI Avatar Videos ----
HEYGEN_API_KEY=xxxxx
HEYGEN_AVATAR_ID=default_avatar
HEYGEN_VOICE_ID=default_voice
NEXT_PUBLIC_HEYGEN_ENABLED=true

# ---- MCP (Model Context Protocol) Servers ----
MCP_SERVER_PORT=3100
MCP_TREND_ANALYSIS_PORT=3101
MCP_PRODUCT_IDEAS_PORT=3102
MCP_CONTENT_GEN_PORT=3103
MCP_MARKET_DATA_PORT=3104
MCP_NICHE_RESEARCH_PORT=3105
MCP_COMPETITOR_INTEL_PORT=3106

# ---- Rate Limiting ----
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ---- Redis (Optional - for caching & rate limiting) ----
REDIS_URL=redis://localhost:6379

# ---- Analytics (Optional) ----
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- Logging ----
LOG_LEVEL=info
ENABLE_AI_LOGGING=true
